#!/usr/bin/env bash

set -o nounset
set -o errexit
trap 'echo "Aborting due to errexit on line $LINENO. Exit code: $?" >&2' ERR
set -o errtrace
set -o pipefail
IFS=$'\n\t'

echo "📦 Installing Claude Code skills..."

{{- if eq .chezmoi.os "linux" }}
# Activate mise to ensure Node.js is available
eval "$(~/.local/bin/mise activate bash)"
{{- end }}

# superpowersスキルはClaude Codeプラグインで提供されるため除外
# (opencode向けには別スクリプトでセットアップ)

# Claude Code専用スキル (プラグイン代替なし)
npx skills add https://github.com/vercel-labs/skills --skill find-skills -y --global -a claude-code
npx skills add https://github.com/antfu/skills --skill slidev -y --global -a claude-code

# 旧スキルのクリーンアップ
rm -rf ~/.agents/skills/brainstorming ~/.agents/skills/using-git-worktrees
rm -f ~/.claude/skills/brainstorming ~/.claude/skills/using-git-worktrees

echo "✅ Claude Code skills installed successfully!"
